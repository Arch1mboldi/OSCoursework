--- a/arch/x86/entry/syscalls/syscall_64.tbl
+++ b/arch/x86/entry/syscalls/syscall_64.tbl
@@ -XXX,3 +XXX,6 @@
 # 在文件末尾添加以下三行 (系统调用号需根据实际最后一条递增)
+# 如果当前最后一条是 461，则从 462 开始
+462	common	proc_collect		sys_proc_collect
+463	common	proc_snapshot		sys_proc_snapshot
+464	common	proc_stat		sys_proc_stat

# ===== 操作说明 =====
# 1. 查看当前最大系统调用号:
#      tail -5 arch/x86/entry/syscalls/syscall_64.tbl
# 2. 在文件末尾添加上述三行，确保系统调用号连续
# 3. 格式: <号> <abi> <名称> <入口函数>
#    - common = 64位 和 x32 ABI 均可用
#    - 入口函数名与 SYSCALL_DEFINE 宏参数对应:
#      SYSCALL_DEFINE3(proc_collect, ...) -> sys_proc_collect
